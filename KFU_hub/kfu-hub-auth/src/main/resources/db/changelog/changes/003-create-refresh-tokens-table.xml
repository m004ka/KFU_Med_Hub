<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-create-refresh-tokens-table" author="kfu-hub">
        <createTable tableName="refresh_tokens" schemaName="auth" remarks="Refresh токены">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="token" type="VARCHAR(512)" remarks="Значение refresh токена">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_refresh_tokens_token"/>
            </column>
            <column name="user_id" type="UUID" remarks="Владелец токена">
                <constraints nullable="false"
                             foreignKeyName="fk_refresh_token_user"
                             references="auth.users(id)"/>
            </column>
            <column name="expires_at" type="TIMESTAMP" remarks="Срок действия">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP"/>
        </createTable>

        <createIndex tableName="refresh_tokens" schemaName="auth" indexName="idx_refresh_tokens_user_id">
            <column name="user_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="refresh_tokens" schemaName="auth"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
